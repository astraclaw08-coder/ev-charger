NODE_ENV=production
PORT=3001
DATABASE_URL=<prod-database-url>
OCPP_INTERNAL_URL=https://<prod-ocpp-internal-url>
OCPP_WS_URL=wss://<prod-ocpp-ws-url>
LOG_LEVEL=info

# Keycloak (production)
KEYCLOAK_BASE_URL=https://<prod-keycloak-host>
KEYCLOAK_REALM=<prod-realm>
KEYCLOAK_PORTAL_CLIENT_ID=<prod-portal-client-id>
KEYCLOAK_PORTAL_CLIENT_SECRET=<prod-portal-client-secret>
KEYCLOAK_ADMIN_CLIENT_ID=<prod-admin-client-id>
KEYCLOAK_ADMIN_CLIENT_SECRET=<prod-admin-client-secret>
SUPER_ADMIN_BOOTSTRAP_SECRET=<prod-bootstrap-secret>
KEYCLOAK_OWNER_ROLES=owner,operator

# Keycloak auth cutover direction
AUTH_PROVIDER_PRIMARY=keycloak
AUTH_PROVIDER_DUAL_ACCEPT=false
