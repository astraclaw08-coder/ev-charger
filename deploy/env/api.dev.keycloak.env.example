NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://evcharger:evcharger@localhost:5432/evcharger
OCPP_INTERNAL_URL=http://127.0.0.1:9000
OCPP_WS_URL=ws://localhost:9000
LOG_LEVEL=info

# Keycloak (development)
KEYCLOAK_BASE_URL=https://<dev-keycloak-host>
KEYCLOAK_REALM=<dev-realm>
KEYCLOAK_PORTAL_CLIENT_ID=<dev-portal-client-id>
KEYCLOAK_PORTAL_CLIENT_SECRET=<dev-portal-client-secret>
KEYCLOAK_ADMIN_CLIENT_ID=<dev-admin-client-id>
KEYCLOAK_ADMIN_CLIENT_SECRET=<dev-admin-client-secret>
SUPER_ADMIN_BOOTSTRAP_SECRET=<dev-bootstrap-secret>
KEYCLOAK_OWNER_ROLES=owner,operator

# Keycloak auth cutover direction
AUTH_PROVIDER_PRIMARY=keycloak
AUTH_PROVIDER_DUAL_ACCEPT=false
