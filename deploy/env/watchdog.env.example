# Example environment for production watchdog + systemd units
# Copy to /etc/ev-charger/ev-charger.env (or your chosen path) and adjust values.

NODE_ENV=production

# ---- Watchdog monitoring cadence ----
WATCHDOG_INTERVAL_MS=10000
WATCHDOG_HTTP_TIMEOUT_MS=3000
WATCHDOG_RESTART_WINDOW_MS=600000
WATCHDOG_RESTART_MAX=4
WATCHDOG_RESTART_COOLDOWN_MS=30000

# ---- Units monitored by prod-health-monitor.js ----
WATCHDOG_API_UNIT=ev-api.service
WATCHDOG_OCPP_UNIT=ev-ocpp.service
# WATCHDOG_ENABLE_PORTAL=true
# WATCHDOG_PORTAL_UNIT=ev-portal.service

# ---- Health probe endpoints ----
WATCHDOG_API_HEALTH_URL=http://127.0.0.1:3001/health
WATCHDOG_OCPP_HEALTH_URL=http://127.0.0.1:9000/health
# Optional token expectations (comma-separated). Leave unset for sane defaults.
# Example for hosted API that only returns {"status":"ok"}:
# WATCHDOG_API_EXPECT="\"status\":\"ok\""
# WATCHDOG_OCPP_EXPECT="\"status\":\"ok\""
# WATCHDOG_PORTAL_HEALTH_URL=http://127.0.0.1:4175/

# ---- Alert integrations ----
# 1) Command-based alert hook (recommended for Telegram wrapper)
WATCHDOG_ALERT_COMMAND=/opt/ev-charger/scripts/alert-telegram.sh

# 2) Generic webhook destination (optional)
# WATCHDOG_ALERT_WEBHOOK_URL=https://hooks.example.com/services/ev-watchdog

# Telegram integration used by scripts/alert-telegram.sh
# TELEGRAM_BOT_TOKEN=123456:replace-me
# TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_API_BASE=https://api.telegram.org
# TELEGRAM_DISABLE=false
