# Portal (dev/local)
VITE_API_URL=http://localhost:3001
VITE_AUTH_MODE=keycloak
VITE_CLERK_PUBLISHABLE_KEY=
VITE_DEV_OPERATOR_ID=operator-001

# Use DEV web Maps key only for local dev.
# Production key must be stored in Vercel env vars (production scope), not committed.
VITE_GOOGLE_MAPS_API_KEY=__SET_DEV_WEB_KEY__

# Optional display label/version for local builds
VITE_ENV_LABEL=DEV
VITE_APP_VERSION=dev-local
