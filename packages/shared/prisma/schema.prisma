generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ChargerStatus {
  OFFLINE
  ONLINE
  FAULTED
}

enum ConnectorStatus {
  AVAILABLE
  PREPARING
  CHARGING
  SUSPENDED_EVSE
  SUSPENDED_EV
  FINISHING
  RESERVED
  UNAVAILABLE
  FAULTED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum OcppDirection {
  INBOUND
  OUTBOUND
}

enum UptimeEventType {
  ONLINE
  OFFLINE
  FAULTED
  RECOVERED
  SCHEDULED_MAINTENANCE
  UTILITY_INTERRUPTION
  VEHICLE_FAULT
  VANDALISM
  FORCE_MAJEURE
}

enum OcppOutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ReservationStatus {
  PENDING       // Created, awaiting OCPP confirmation or software-only hold
  CONFIRMED     // OCPP ReserveNow accepted OR software-only confirmed
  FULFILLED     // Driver started a session against this reservation
  EXPIRED       // Hold window elapsed without session start
  CANCELLED     // Driver or operator cancelled
  REJECTED      // OCPP ReserveNow rejected by charger
}

enum SmartChargingScope {
  CHARGER
  GROUP
  SITE
}

/// Hybrid-B fleet charging policy. A FleetPolicy declares an allowed delivery
/// window + max current for a set of drivers (matched by idTag prefix) at a site.
/// Behavior (Phase ≥2): server always Accepts StartTransaction for matched idTags,
/// then modulates current via SetChargingProfile — full maxAmps inside window,
/// 0 A outside. Phase 1 only scaffolds the schema + window math; no runtime
/// behavior change until FLEET_GATED_SESSIONS_ENABLED feature flag is turned on.
/// Connector charging mode for TASK-0208 Phase 3 (Fleet-Auto).
/// PUBLIC = default, driver/operator-triggered start.
/// FLEET_AUTO = server-initiated RemoteStartTransaction on plug-in
/// (Preparing) when the two-tier rollout gate is satisfied. See
/// tasks/task-0208-phase3-fleet-auto-redesign.md.
enum ChargingMode {
  PUBLIC
  FLEET_AUTO
}

enum FleetPolicyStatus {
  DRAFT     // schema row created, not yet active
  ENABLED   // active — scheduler will modulate current for matching sessions
  DISABLED  // temporarily paused (server falls back to legacy allow/deny)
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Site {
  id               String              @id @default(uuid())
  name             String
  address          String
  lat              Float
  lng              Float
  operatorId       String
  pricingMode      String              @default("flat") // flat | tou
  pricePerKwhUsd   Float               @default(0.35)
  idleFeePerMinUsd Float               @default(0.08)
  activationFeeUsd Float               @default(0)
  gracePeriodMin   Int                 @default(10)
  softwareVendorFeeMode  String        @default("none") // none | percentage_total | fixed_per_kwh | fixed_per_minute
  softwareVendorFeeValue Float         @default(0)
  softwareFeeIncludesActivation Boolean @default(false)
  touWindows       Json?
  timeZone         String              @default("America/Los_Angeles") // IANA timezone for TOU pricing + smart charging
  organizationName String?             // @deprecated — use organizationId relation
  portfolioName    String?             // @deprecated — use portfolioId relation
  organizationId   String?
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  portfolioId      String?
  portfolio        Portfolio?          @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  // Session safety limits (null = no limit)
  maxChargeDurationMin  Int?    // Auto-stop active charging after N minutes
  maxIdleDurationMin    Int?    // Auto-stop/disconnect after N minutes idle post-charge
  maxSessionCostUsd     Float?  // Auto-stop when estimated session cost reaches this cap (USD)
  // Reservation settings
  reservationEnabled        Boolean  @default(false)
  reservationMaxDurationMin Int      @default(30)   // max hold window in minutes
  reservationFeeUsd         Float    @default(0)    // 0 = free reservations
  reservationCancelGraceMin Int      @default(5)    // minutes where cancel = full refund
  // TASK-0208 Phase 3 Slice A — site-level Fleet-Auto pilot rollout flag.
  // DB-backed; toggled via operator portal (Slice B). Audit-logged on flip
  // via writeFleetRolloutAudit(). Off by default — schema/code can ship
  // dark in prod with no behavior change. See §0 #5 of redesign doc.
  fleetAutoRolloutEnabled   Boolean  @default(false)
  chargers         Charger[]
  chargerGroups    ChargerGroup[]
  chargingProfiles SmartChargingProfile[]
  sessionFacts     SessionFact[]
  rebateIntervals  RebateInterval15m[]
  siteDailyFacts   SiteDailyFact[]
  reservations     Reservation[]
  fleetPolicies    FleetPolicy[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([operatorId])
  @@index([organizationId])
  @@index([portfolioId])
}

/// Per-site fleet charging policy (Hybrid-B, TASK-0208).
/// Matches drivers by idTagPrefix; inside the weekly window the server allows
/// up to maxAmps, outside the window it drops current to 0 A via TxProfile.
/// Windows use the same {day, start HH:mm, end HH:mm} shape as TouWindow, in
/// the site's local timezone. JSON shape: { windows: FleetWindow[] }.
model FleetPolicy {
  id              String            @id @default(uuid())
  siteId          String
  site            Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name            String
  status          FleetPolicyStatus @default(DRAFT)
  idTagPrefix     String            // e.g. "FLEET-" — matched at Authorize/StartTransaction
  maxAmps         Int               @default(32)
  ocppStackLevel  Int               @default(90) // above CHARGER=50 + priority; below emergency=99
  windowsJson     Json              // { windows: [{ day, start, end }] } — see FleetWindow type
  notes           String?
  createdByOperatorId String?
  updatedByOperatorId String?
  // TASK-0208 Phase 3 Slice A — Fleet-Auto activation fields.
  // alwaysOn: bypasses windowsJson evaluation (24/7 fleet sites).
  // autoStartIdTag: idTag the OCPP server uses for server-initiated
  // RemoteStartTransaction on plug-in. Backfilled by the Slice A
  // migration; required in API on new/edited policies in Slice B.
  alwaysOn        Boolean           @default(false)
  autoStartIdTag  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Direct connector assignments (Phase 3 / Fleet-Auto). Replaces the
  // legacy idTagPrefix-match path. Hybrid-B prefix matching survives
  // only as compatibility until Slice G removes the Authorize branch.
  connectors      Connector[]

  @@unique([siteId, idTagPrefix])
  @@index([siteId, status])
  @@index([status])
}

model Charger {
  id              String              @id @default(uuid())
  siteId          String?
  site            Site?               @relation(fields: [siteId], references: [id], onDelete: SetNull)
  groupId         String?
  group           ChargerGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  ocppId          String              @unique // used in OCPP WebSocket path: /ocpp/{ocppId}
  serialNumber    String              @unique
  model           String
  vendor          String
  password        String // OCPP basic auth password (hashed)
  status          ChargerStatus       @default(OFFLINE)
  lastHeartbeat   DateTime?
  connectors      Connector[]
  stateTransitions ConnectorStateTransition[]
  ocppLogs        OcppLog[]
  uptimeEvents    UptimeEvent[]
  connectionEvents ChargerConnectionEvent[]
  uptimeDaily     UptimeDaily[]
  outboxEvents    OcppEventOutbox[]
  chargingProfiles SmartChargingProfile[]
  smartChargingStates SmartChargingState[]
  sessionFacts    SessionFact[]
  rebateIntervals RebateInterval15m[]
  favoritedBy     UserFavoriteCharger[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  healthAssessments ChargerHealthAssessment[]

  @@index([siteId])
  @@index([groupId])
  @@index([status])
}

model ChargerHealthAssessment {
  id             String   @id @default(uuid())
  chargerId      String
  charger        Charger  @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  connectorId    Int?
  overallScore   Int
  overallStatus  String   // healthy | degraded | critical | offline
  reportJson     Json
  requestedBy    String   // operator ID
  createdAt      DateTime @default(now())

  @@index([chargerId, createdAt])
}

model ChargerGroup {
  id          String                @id @default(uuid())
  name        String
  description String?
  siteId      String?
  site        Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  chargers    Charger[]
  profiles    SmartChargingProfile[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([siteId])
  @@index([name])
}

model SmartChargingProfile {
  id                  String             @id @default(uuid())
  name                String
  scope               SmartChargingScope
  enabled             Boolean            @default(true)
  priority            Int                @default(0)
  defaultLimitKw      Float?
  schedule            Json?
  validFrom           DateTime?
  validTo             DateTime?
  siteId              String?
  site                Site?              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  chargerGroupId      String?
  chargerGroup        ChargerGroup?      @relation(fields: [chargerGroupId], references: [id], onDelete: Cascade)
  chargerId           String?
  charger             Charger?           @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  createdByOperatorId String?
  updatedByOperatorId String?
  ocppStackLevelBase  Int                @default(50)
  states              SmartChargingState[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([scope, enabled, priority])
  @@index([siteId, scope, enabled])
  @@index([chargerGroupId, scope, enabled])
  @@index([chargerId, scope, enabled])
}

model SmartChargingState {
  id              String              @id @default(uuid())
  chargerId       String
  charger         Charger             @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  effectiveLimitKw Float
  fallbackApplied Boolean             @default(false)
  sourceScope     SmartChargingScope?
  sourceProfileId String?
  sourceProfile   SmartChargingProfile? @relation(fields: [sourceProfileId], references: [id], onDelete: SetNull)
  sourceWindowId  String?
  sourceReason    String
  status          String
  lastAttemptAt   DateTime
  lastAppliedAt   DateTime?
  lastError       String?
  ocppChargingProfileId Int?
  ocppStackLevel        Int?
  compositeScheduleVerified   Boolean   @default(false)
  compositeScheduleVerifiedAt DateTime?
  profileFingerprint String?  // SHA-256 hash of profile definition; detects server-side changes
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([chargerId, sourceProfileId])
  @@index([chargerId])
  @@index([status, updatedAt])
  @@index([sourceProfileId])
}

model Connector {
  id                String                     @id @default(uuid())
  chargerId         String
  charger           Charger                    @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  connectorId       Int // OCPP connector number (1-indexed per charger)
  status            ConnectorStatus            @default(UNAVAILABLE)
  // TASK-0208 Phase 3 Slice A — Fleet-Auto activation config.
  // chargingMode: PUBLIC (default) or FLEET_AUTO. FLEET_AUTO connectors
  //   may auto-start sessions on plug-in when the rollout gate allows.
  // fleetPolicyId: direct FK assignment (not idTag prefix lookup).
  // fleetAutoRolloutEnabled: per-connector override of the site's
  //   pilot rollout flag. null = inherit from Site.fleetAutoRolloutEnabled.
  //   Toggled via operator portal (Slice B); audit-logged.
  chargingMode      ChargingMode               @default(PUBLIC)
  fleetPolicyId     String?
  fleetPolicy       FleetPolicy?               @relation(fields: [fleetPolicyId], references: [id], onDelete: SetNull)
  fleetAutoRolloutEnabled Boolean?
  sessions          Session[]
  stateTransitions  ConnectorStateTransition[]
  reservations      Reservation[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@unique([chargerId, connectorId])
  @@index([status])
  @@index([chargingMode])
  @@index([fleetPolicyId])
}

model ConnectorStateTransition {
  id             String          @id @default(uuid())
  chargerId      String
  charger        Charger         @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  connectorRefId String
  connector      Connector       @relation(fields: [connectorRefId], references: [id], onDelete: Cascade)
  connectorId    Int
  fromStatus     ConnectorStatus
  toStatus       ConnectorStatus
  transitionType String
  occurredAt     DateTime
  payloadTs      DateTime?
  createdAt      DateTime        @default(now())

  @@index([chargerId, connectorId, occurredAt])
  @@index([transitionType, occurredAt])
}

model Session {
  id              String              @id @default(uuid())
  connectorId     String
  connector       Connector           @relation(fields: [connectorId], references: [id])
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  transactionId   Int?                @unique // OCPP transactionId assigned by server
  idTag           String // OCPP idTag used to start session
  startedAt       DateTime            @default(now())
  stoppedAt       DateTime?
  meterStart      Float? // Wh at session start
  meterStop       Float? // Wh at session end
  kwhDelivered    Float? // computed: (meterStop - meterStart) / 1000
  ratePerKwh      Float? // price locked at session start (USD)
  status          SessionStatus       @default(ACTIVE)
  payment         Payment?
  // ── Hybrid-B fleet gating timeline (TASK-0208, Phase 1 scaffold) ─────────
  // Distinguishes "plugged but gated at 0 A" from "delivering energy" from "idle post-charge".
  // Populated only for fleet-gated sessions; null for legacy sessions.
  plugInAt        DateTime?           // first Preparing/SuspendedEV after plug-in
  firstEnergyAt   DateTime?           // first MeterValues sample with non-zero power
  lastEnergyAt    DateTime?           // last MeterValues sample with non-zero power
  fleetPolicyId   String?             // set when session matched a FleetPolicy at Authorize
  sessionFact     SessionFact?
  billingSnapshot SessionBillingSnapshot?
  rebateIntervals RebateInterval15m[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId])
  @@index([connectorId])
  @@index([status])
}

model User {
  id              String    @id @default(uuid())
  clerkId         String    @unique
  email           String    @unique
  name            String?
  phone           String?
  homeAddress     String?
  homeSiteAddress String?
  homeCity        String?
  homeState       String?
  homeZipCode     String?
  paymentProfile    String?
  stripeCustomerId       String?   @unique // Stripe customer ID for payment methods
  defaultPaymentMethodId String?          // Stripe payment method ID used for charges
  vehicleName       String?   // Custom nickname (e.g. "My Daily Driver")
  vehicleMake     String?   // e.g. "Tesla"
  vehicleModel    String?   // e.g. "Model 3"
  vehicleYear     String?   // e.g. "2023"
  idTag           String    @unique // OCPP idTag for this driver (max 20 chars)
  sessions        Session[]
  payments        Payment[]
  reservations    Reservation[]
  favoriteChargers UserFavoriteCharger[]
  inAppNotificationDeliveries InAppNotificationDelivery[]
  authSessions    AuthSession[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UserFavoriteCharger {
  userId    String
  chargerId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charger   Charger  @relation(fields: [chargerId], references: [id], onDelete: Cascade)

  @@id([userId, chargerId])
  @@index([userId, createdAt])
  @@index([chargerId, createdAt])
}

model Payment {
  id               String        @id @default(uuid())
  sessionId        String        @unique
  session          Session       @relation(fields: [sessionId], references: [id])
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  stripeIntentId   String?
  stripeCustomerId String?
  amountCents      Int? // in USD cents
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

/// Immutable billing record captured at session completion.
/// Locks the pricing inputs (rates, TOU windows, timezone) that were active
/// at the time of the transaction so future config changes never alter history.
/// Exception: may be overwritten programmatically for error corrections,
/// but NEVER when payment status is CAPTURED or REFUNDED.
model SessionBillingSnapshot {
  id                   String    @id @default(uuid())
  sessionId            String    @unique
  session              Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ── Pricing inputs locked at capture time ──────────────────────────────
  pricingMode          String                    // 'flat' | 'tou'
  pricePerKwhUsd       Float
  idleFeePerMinUsd     Float
  activationFeeUsd     Float
  gracePeriodMin       Int
  touWindowsJson       Json?                     // exact touWindows array used for billing
  siteTimeZone         String?                   // IANA tz string, null = America/Los_Angeles default

  // ── Billing outputs ─────────────────────────────────────────────────────
  kwhDelivered         Float?
  durationMinutes      Float?
  energyAmountUsd      Float?
  idleAmountUsd        Float?
  activationAmountUsd  Float?
  grossAmountUsd       Float?
  vendorFeeUsd         Float?
  netAmountUsd         Float?
  billingBreakdownJson Json?                     // full BillingBreakdown from computeSessionAmounts

  // ── Timing locked at capture time ───────────────────────────────────────
  chargingStartedAt    DateTime?                 // session.startedAt
  chargingStoppedAt    DateTime?                 // idleStartedAt if idle present, else plugOutAt
  idleStartedAt        DateTime?
  idleStoppedAt        DateTime?
  plugOutAt            DateTime?

  // ── Receipt delivery ────────────────────────────────────────────────────
  receiptSentAt        DateTime?                 // set when receipt email sent successfully

  // ── Hybrid-B fleet receipts (TASK-0208, Phase 1 scaffold) ──────────────
  // Captures how much wall-clock time the vehicle was plugged in but held at
  // 0 A waiting for the allowed window (driver pays $0 for this interval by
  // default — pricing policy TBD).
  preDeliveryGatedMinutes Float?
  gatedPricingMode        String?   // 'free' | 'flat' | 'tou' — for future use

  snapshotVersion      String    @default("v1")
  capturedAt           DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([sessionId])
}

model SessionFact {
  id               String        @id @default(uuid())
  sessionId        String        @unique
  session          Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chargerId        String
  charger          Charger       @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  siteId           String
  site             Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  organizationName String?
  portfolioName    String?
  startedAt        DateTime
  stoppedAt        DateTime?
  durationMinutes  Int?
  energyKwh        Decimal?      @db.Decimal(18, 6)
  revenueUsd       Decimal?      @db.Decimal(18, 6)
  status           SessionStatus
  sourceVersion    String        @default("v1")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([siteId, startedAt])
  @@index([chargerId, startedAt])
  @@index([organizationName, startedAt])
  @@index([portfolioName, startedAt])
}

model RebateInterval15m {
  id               String   @id @default(uuid())
  siteId           String
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  chargerId        String
  charger          Charger  @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  sessionId        String?
  session          Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  connectorId      Int
  intervalStart    DateTime
  intervalEnd      DateTime
  intervalMinutes  Int      @default(15)
  energyKwh        Decimal  @db.Decimal(18, 6)
  avgPowerKw       Decimal  @db.Decimal(18, 6)
  maxPowerKw       Decimal? @db.Decimal(18, 6)
  portStatus       String?
  vehicleConnected Boolean?
  dataQualityFlag  String?
  sourceVersion    String   @default("v1")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([chargerId, connectorId, intervalStart, intervalEnd, sourceVersion])
  @@index([siteId, intervalStart])
  @@index([sessionId, intervalStart])
}

model SiteDailyFact {
  id              String   @id @default(uuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  day             DateTime
  sessionsCount   Int      @default(0)
  totalEnergyKwh  Decimal  @db.Decimal(18, 6)
  totalRevenueUsd Decimal? @db.Decimal(18, 6)
  avgPowerKw      Decimal? @db.Decimal(18, 6)
  sourceVersion   String   @default("v1")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([siteId, day, sourceVersion])
  @@index([day])
}

model OcppLog {
  id          String        @id @default(uuid())
  chargerId   String
  charger     Charger       @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  direction   OcppDirection
  messageType Int // 2=CALL, 3=CALLRESULT, 4=CALLERROR
  messageId   String
  action      String? // e.g., "BootNotification" (null for CALLRESULT/CALLERROR)
  payload     Json
  createdAt   DateTime      @default(now())

  @@index([chargerId])
  @@index([createdAt])
}

model OcppEventOutbox {
  id             String           @id @default(uuid())
  chargerId      String
  charger        Charger          @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  eventType      String
  direction      OcppDirection    @default(INBOUND)
  payload        Json
  idempotencyKey String           @unique
  status         OcppOutboxStatus @default(PENDING)
  attempts       Int              @default(0)
  nextAttemptAt  DateTime         @default(now())
  lastError      String?
  processedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([status, nextAttemptAt])
  @@index([chargerId, createdAt])
  @@index([eventType, createdAt])
}

model UptimeEvent {
  id          String          @id @default(uuid())
  chargerId   String
  charger     Charger         @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  connectorId Int?
  event       UptimeEventType
  reason      String?
  errorCode   String?
  createdAt   DateTime        @default(now())

  @@index([chargerId, createdAt])
  @@index([createdAt])
  @@index([event])
}

model ChargerConnectionEvent {
  id              String   @id @default(uuid())
  chargerId        String
  charger          Charger  @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  ocppId           String
  event            String   // CONNECTED | DISCONNECTED
  sessionId        String?
  connectedAt      DateTime?
  disconnectedAt   DateTime?
  durationMs       Int?
  closeCode        Int?
  closeReason      String?
  remoteAddress    String?
  host             String?
  path             String?
  userAgent        String?
  transportMeta    Json?
  createdAt        DateTime @default(now())

  @@index([chargerId, createdAt])
  @@index([ocppId, createdAt])
  @@index([event, createdAt])
  @@index([sessionId])
}

model UptimeDaily {
  id                    String   @id @default(uuid())
  chargerId             String
  charger               Charger  @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  date                  DateTime @db.Date
  totalSeconds          Int
  availableSeconds      Int
  outageSeconds         Int
  excludedOutageSeconds Int      @default(0)
  uptimePercent         Float
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([chargerId, date])
  @@index([chargerId])
  @@index([date])
}

model AdminAuditEvent {
  id           String   @id @default(uuid())
  operatorId   String
  action       String
  targetUserId String?
  targetEmail  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([operatorId, createdAt])
  @@index([action, createdAt])
  @@index([targetUserId])
}

model InAppNotificationCampaign {
  id               String   @id @default(uuid())
  createdByOperatorId String
  targetMode       String
  targetUserIds    String[]
  targetEmails     String[]
  title            String
  message          String
  actionLabel      String?
  actionUrl        String?
  deepLink         String?
  sentAt           DateTime @default(now())
  createdAt        DateTime @default(now())
  deliveries       InAppNotificationDelivery[]

  @@index([createdByOperatorId, sentAt])
  @@index([sentAt])
}

model InAppNotificationDelivery {
  id          String   @id @default(uuid())
  campaignId  String
  campaign    InAppNotificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@unique([campaignId, userId])
  @@index([userId, createdAt])
  @@index([campaignId, createdAt])
}

model PortalSettings {
  id                         String   @id @default(uuid())
  scopeKey                   String   @unique
  organizationName           String?
  organizationDefaultSite    String?
  organizationPortfolio      String?
  organizationBillingAddress String?
  supportContactEmail        String?
  supportContactPhone        String?
  profileDisplayName         String?
  profileTimezone            String?
  remittanceBankName         String?
  remittanceAccountType      String?
  remittanceEmail            String?
  routingNumber              String?
  accountNumber              String?
  // AI Assistant — OpenAI OAuth
  openaiAccessToken    String?   @db.Text
  openaiRefreshToken   String?   @db.Text
  openaiTokenExpiresAt DateTime?
  openaiConnectedEmail String?
  openaiConnectedAt    DateTime?
  updatedByOperatorId        String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([scopeKey])
}

model OperatorNotificationPreference {
  id            String   @id @default(uuid())
  operatorId    String   @unique
  emailEnabled  Boolean  @default(true)
  smsEnabled    Boolean  @default(false)
  outageAlerts  Boolean  @default(true)
  billingAlerts Boolean  @default(true)
  weeklyDigest  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChargerModelCatalog {
  id                  String   @id @default(uuid())
  scopeKey            String
  modelCode           String
  vendor              String
  displayName         String
  maxKw               Float
  connectorType       String
  isActive            Boolean  @default(true)
  updatedByOperatorId String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([scopeKey, modelCode])
  @@index([scopeKey, isActive])
}

model AuthOtpChallenge {
  id            String    @id @default(uuid())
  channel       String    // EMAIL or SMS
  identifier    String    // normalized email or E.164 phone
  codeHash      String
  maxAttempts   Int       @default(5)
  attemptCount  Int       @default(0)
  issuedIp      String?
  lastSentAt    DateTime  @default(now())
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([identifier, channel])
}

model AuthSession {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  provider    String    // otp-email, otp-sms, keycloak-password
  issuedIp    String?
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Organization & Portfolio entities ──

model Organization {
  id                  String      @id @default(uuid())
  name                String      @unique
  billingAddress      String?
  contactEmail        String?
  contactPhone        String?
  status              String      @default("active") // active | inactive
  createdByOperatorId String
  sites               Site[]
  portfolios          Portfolio[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Portfolio {
  id                  String       @id @default(uuid())
  name                String
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  description         String?
  isGlobal            Boolean      @default(false) // true = admin-assigned cross-org
  createdByOperatorId String
  sites               Site[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model SavedReport {
  id          String   @id @default(uuid())
  operatorId  String
  name        String
  reportType  String   @default("interval_usage") // extensible for future report types
  config      Json     // filter criteria: siteId, chargerIds, dateRange, intervalMinutes, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([operatorId, name])
  @@index([operatorId, reportType])
}

// ─── Reservations ────────────────────────────────────────────────────────────

model Reservation {
  id                 String            @id @default(uuid())
  reservationId      Int               @unique @default(autoincrement()) // OCPP-compatible integer ID
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  connectorRefId     String            // FK to Connector.id (the Prisma UUID)
  connector          Connector         @relation(fields: [connectorRefId], references: [id])
  siteId             String
  site               Site              @relation(fields: [siteId], references: [id])
  status             ReservationStatus @default(PENDING)
  holdStartsAt       DateTime          @default(now())
  holdExpiresAt      DateTime          // When the reservation auto-expires
  ocppSent           Boolean           @default(false)  // Was ReserveNow sent to charger?
  ocppAccepted       Boolean?          // null = not sent, true/false = charger response
  fulfilledSessionId String?           @unique // Set when session starts against this reservation
  cancelledBy        String?           // 'driver' | 'operator' | 'system'
  cancelReason       String?
  // Reservation fee tracking
  feeAmountCents            Int?      // fee charged at creation (null = no fee)
  feeStripePaymentIntentId  String?   // Stripe PaymentIntent id (manual capture)
  feeStatus                 String?   // PENDING | CAPTURED | REFUNDED | VOIDED | FAILED
  feeCancelGraceExpiresAt   DateTime? // when grace period ends (after this, fee is non-refundable)
  feeRefundedAt             DateTime? // when refund/void was issued
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([userId, status])
  @@index([connectorRefId, status])
  @@index([siteId, status])
  @@index([holdExpiresAt, status])
}
