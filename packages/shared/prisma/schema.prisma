generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ChargerStatus {
  OFFLINE
  ONLINE
  FAULTED
  DEGRADED
}

enum ConnectorStatus {
  AVAILABLE
  PREPARING
  CHARGING
  SUSPENDED_EVSE
  SUSPENDED_EV
  FINISHING
  RESERVED
  UNAVAILABLE
  FAULTED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum OcppDirection {
  INBOUND
  OUTBOUND
}

enum UptimeEventType {
  ONLINE
  OFFLINE
  FAULTED
  DEGRADED
  RECOVERED
}

enum OcppOutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Site {
  id               String    @id @default(uuid())
  name             String
  address          String
  lat              Float
  lng              Float
  operatorId       String
  pricingMode      String    @default("flat") // flat | tou
  pricePerKwhUsd   Float     @default(0.35)
  idleFeePerMinUsd Float     @default(0.08)
  activationFeeUsd Float     @default(0)
  gracePeriodMin   Int       @default(10)
  touWindows       Json?
  organizationName String?
  portfolioName    String?
  chargers         Charger[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([operatorId])
}

model Charger {
  id            String        @id @default(uuid())
  siteId        String
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ocppId        String        @unique  // used in OCPP WebSocket path: /ocpp/{ocppId}
  serialNumber  String        @unique
  model         String
  vendor        String
  password      String        // OCPP basic auth password (hashed)
  status        ChargerStatus @default(OFFLINE)
  lastHeartbeat DateTime?
  connectors    Connector[]
  ocppLogs      OcppLog[]
  uptimeEvents  UptimeEvent[]
  outboxEvents  OcppEventOutbox[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([siteId])
  @@index([status])
}

model Connector {
  id          String          @id @default(uuid())
  chargerId   String
  charger     Charger         @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  connectorId Int             // OCPP connector number (1-indexed per charger)
  status      ConnectorStatus @default(UNAVAILABLE)
  sessions    Session[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([chargerId, connectorId])
  @@index([status])
}

model Session {
  id            String        @id @default(uuid())
  connectorId   String
  connector     Connector     @relation(fields: [connectorId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  transactionId Int?          @unique  // OCPP transactionId assigned by server
  idTag         String        // OCPP idTag used to start session
  startedAt     DateTime      @default(now())
  stoppedAt     DateTime?
  meterStart    Float?        // Wh at session start
  meterStop     Float?        // Wh at session end
  kwhDelivered  Float?        // computed: (meterStop - meterStart) / 1000
  ratePerKwh    Float?        // price locked at session start (USD)
  status        SessionStatus @default(ACTIVE)
  payment       Payment?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([connectorId])
  @@index([status])
}

model User {
  id        String    @id @default(uuid())
  clerkId   String    @unique
  email     String    @unique
  name           String?
  phone          String?
  homeAddress    String?
  homeSiteAddress String?
  homeCity        String?
  homeState       String?
  homeZipCode     String?
  paymentProfile String?
  idTag          String    @unique  // OCPP idTag for this driver (max 20 chars)
  sessions  Session[]
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Payment {
  id               String        @id @default(uuid())
  sessionId        String        @unique
  session          Session       @relation(fields: [sessionId], references: [id])
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  stripeIntentId   String?
  stripeCustomerId String?
  amountCents      Int?          // in USD cents
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model OcppLog {
  id          String        @id @default(uuid())
  chargerId   String
  charger     Charger       @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  direction   OcppDirection
  messageType Int           // 2=CALL, 3=CALLRESULT, 4=CALLERROR
  messageId   String
  action      String?       // e.g., "BootNotification" (null for CALLRESULT/CALLERROR)
  payload     Json
  createdAt   DateTime      @default(now())

  @@index([chargerId])
  @@index([createdAt])
}


model OcppEventOutbox {
  id             String           @id @default(uuid())
  chargerId      String
  charger        Charger          @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  eventType      String
  direction      OcppDirection    @default(INBOUND)
  payload        Json
  idempotencyKey String           @unique
  status         OcppOutboxStatus @default(PENDING)
  attempts       Int              @default(0)
  nextAttemptAt  DateTime         @default(now())
  lastError      String?
  processedAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([status, nextAttemptAt])
  @@index([chargerId, createdAt])
  @@index([eventType, createdAt])
}

model UptimeEvent {
  id          String          @id @default(uuid())
  chargerId   String
  charger     Charger         @relation(fields: [chargerId], references: [id], onDelete: Cascade)
  connectorId Int?
  event       UptimeEventType
  reason      String?
  errorCode   String?
  createdAt   DateTime        @default(now())

  @@index([chargerId, createdAt])
  @@index([createdAt])
  @@index([event])
}

model AdminAuditEvent {
  id           String   @id @default(uuid())
  operatorId   String
  action       String
  targetUserId String?
  targetEmail  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([operatorId, createdAt])
  @@index([action, createdAt])
  @@index([targetUserId])
}

model PortalSettings {
  id                       String   @id @default(uuid())
  scopeKey                 String   @unique
  organizationName         String?
  organizationDefaultSite  String?
  organizationPortfolio    String?
  organizationBillingAddress String?
  supportContactEmail      String?
  supportContactPhone      String?
  profileDisplayName       String?
  profileTimezone          String?
  remittanceBankName       String?
  remittanceAccountType    String?
  remittanceEmail          String?
  routingNumber            String?
  accountNumber            String?
  updatedByOperatorId      String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([scopeKey])
}

model OperatorNotificationPreference {
  id            String   @id @default(uuid())
  operatorId    String   @unique
  emailEnabled  Boolean  @default(true)
  smsEnabled    Boolean  @default(false)
  outageAlerts  Boolean  @default(true)
  billingAlerts Boolean  @default(true)
  weeklyDigest  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChargerModelCatalog {
  id                  String   @id @default(uuid())
  scopeKey            String
  modelCode           String
  vendor              String
  displayName         String
  maxKw               Float
  connectorType       String
  isActive            Boolean  @default(true)
  updatedByOperatorId String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([scopeKey, modelCode])
  @@index([scopeKey, isActive])
}
