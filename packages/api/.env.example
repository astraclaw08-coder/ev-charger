# ============================================================
# API Environment Configuration
# Dev and prod use IDENTICAL key names — only values differ.
# Copy this file to .env and fill in environment-specific values.
# ============================================================

PORT=3001
DATABASE_URL=postgresql://evcharger:evcharger@localhost:5432/evcharger

# --- OCPP ---
OCPP_INTERNAL_URL=http://127.0.0.1:9000
OCPP_WS_URL=ws://localhost:9000

# --- Keycloak (REQUIRED — API will not start without these) ---
KEYCLOAK_BASE_URL=http://localhost:8090          # dev: localhost, prod: https://keycloak.example.com
KEYCLOAK_REALM=ev-charger-dev                    # dev: ev-charger-dev, prod: ev-charger
KEYCLOAK_PORTAL_CLIENT_ID=ev-charger-portal
KEYCLOAK_PORTAL_CLIENT_SECRET=change-me

# Keycloak admin client (for user management / password reset APIs)
KEYCLOAK_ADMIN_CLIENT_ID=ev-charger-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me

# Owner/operator role names in Keycloak
KEYCLOAK_OWNER_ROLES=owner,operator

# Super admin bootstrap secret (POST /auth/bootstrap-super-admin)
SUPER_ADMIN_BOOTSTRAP_SECRET=change-me

# --- Stripe (optional — leave empty to disable payment endpoints) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Logging ---
LOG_LEVEL=info
