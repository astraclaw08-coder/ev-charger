# Mobile DEV environment (simulator / local stack)
EXPO_PUBLIC_ENV_LABEL=DEV
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001
GOOGLE_MAPS_API_KEY_IOS=<dev_ios_key>
GOOGLE_MAPS_API_KEY_ANDROID=<dev_android_key>
# Optional for dev guest simulation:
# EXPO_PUBLIC_ALLOW_GUEST_TRANSACT=1
# EXPO_PUBLIC_DEV_USER_ID=user-test-driver-001
