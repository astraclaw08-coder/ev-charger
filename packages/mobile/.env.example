# Mobile app env (local/eas)
# Keep DEV and PROD keys separate.

# API endpoints
EXPO_PUBLIC_API_URL_DEV=http://127.0.0.1:3001
EXPO_PUBLIC_API_URL_PROD=https://api-production-26cf.up.railway.app

# DEV keys (local + development profile)
GOOGLE_MAPS_API_KEY_IOS_DEV=__SET_DEV_IOS_KEY__
GOOGLE_MAPS_API_KEY_ANDROID_DEV=__SET_DEV_ANDROID_KEY__
GOOGLE_MAPS_API_KEY_DEV=__SET_DEV_SHARED_KEY_OPTIONAL__

# PROD keys (EAS production profile only)
GOOGLE_MAPS_API_KEY_IOS_PROD=__SET_PROD_IOS_KEY__
GOOGLE_MAPS_API_KEY_ANDROID_PROD=__SET_PROD_ANDROID_KEY__
GOOGLE_MAPS_API_KEY_PROD=__SET_PROD_SHARED_KEY_OPTIONAL__

# Back-compat fallbacks (optional)
GOOGLE_MAPS_API_KEY_IOS=
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY=
