{
  "cli": { "version": ">= 18.0.0", "appVersionSource": "local" },
  "build": {
    "development": {
      "distribution": "internal",
      "developmentClient": true,
      "env": {
        "APP_ENV": "dev",
        "EXPO_PUBLIC_ENV_LABEL": "DEV"
      }
    },
    "rc": {
      "distribution": "internal",
      "ios": { "resourceClass": "m-medium" },
      "env": {
        "APP_ENV": "rc",
        "EXPO_PUBLIC_ENV_LABEL": "RC",
        "EXPO_PUBLIC_API_URL": "https://api-production-26cf.up.railway.app"
      }
    },
    "production": {
      "ios": { "resourceClass": "m-medium" },
      "env": {
        "APP_ENV": "prod",
        "EXPO_PUBLIC_ENV_LABEL": "PROD"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "astraclaw08@gmail.com",
        "ascAppId": "PLACEHOLDER",
        "appleTeamId": "PLACEHOLDER"
      }
    }
  }
}
