{
  "name": "@ev-charger/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_NO_DOTENV=1 APP_ENV=dev expo start --clear --port 8081 --scheme evcharger-dev",
    "dev:prod": "EXPO_NO_DOTENV=1 APP_ENV=prod expo start --clear --port 8083 --scheme evcharger",
    "ios": "LANG=en_US.UTF-8 EXPO_NO_DOTENV=1 APP_ENV=dev EXPO_PUBLIC_API_URL=http://127.0.0.1:3001 expo run:ios --configuration Debug --scheme EVCharger-Dev --port 8081",
    "ios:prod": "LANG=en_US.UTF-8 EXPO_NO_DOTENV=1 APP_ENV=prod expo run:ios --configuration Release --scheme EVCharger-RC --port 8083",
    "android": "APP_ENV=dev expo run:android",
    "android:prod": "APP_ENV=prod expo run:android",
    "build:dev": "eas build --profile development",
    "build:prod": "eas build --profile production",
    "build:production": "eas build --profile production"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^4.6.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stripe/stripe-react-native": "0.58.0",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~55.0.11",
    "expo-auth-session": "~55.0.12",
    "expo-build-properties": "~55.0.11",
    "expo-camera": "~55.0.13",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.12",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.11",
    "expo-location": "~55.1.6",
    "expo-router": "~55.0.10",
    "expo-secure-store": "~55.0.11",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-places-autocomplete": "^2.6.4",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@react-native-community/cli": "^20.1.2",
    "@types/react": "~19.2.10",
    "typescript": "^5.3.0"
  }
}
